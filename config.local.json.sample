{
  "_doc": "Copy to config.local.json and edit. Gitignored — personal to you.",
  "_doc_agent_map": "Keys are agent types (e.g. frontend, Explore). Values override theme/default/config.json agent_map. Only include fields you want to change — unspecified fields inherit from base.",
  "_doc_agent_type_map": "Maps agent types to display names. Hook merges these on top of built-in defaults (general-purpose, Explore, Plan).",
  "_doc_agent_alias_map": "Maps agent types to share a resident character. e.g. review-critic → review-neutral means both use the same sprite.",
  "_doc_available_sprites": "leader, coder_a, coder_b, coder_c, coder_d, coder_e, explorer, planner, robot",
  "_doc_base_agent_map": {
    "main":             "sprite=leader,   displayName=Leader,    resident, idle=(20,4)",
    "general-purpose":  "sprite=coder_c,  displayName=Assistant, resident, idle=(6,15)",
    "Explore":          "sprite=explorer, displayName=Explorer,  resident, idle=(35,20)",
    "Plan":             "sprite=planner,  displayName=Planner,   resident, idle=(21,17)"
  },

  "character_theme": "default",

  "agent_type_map": {
    "_example": "Add your agent types here. These merge with built-in defaults.",
    "everything-claude-code": "ECC",
    "superpowers": "Superpowers",
    "review-neutral": "Reviewer",
    "frontend": "Frontend"
  },

  "agent_alias_map": {
    "_example": "Map multiple agent types to share one character.",
    "review-critic": "review-neutral",
    "review-advocate": "review-neutral"
  },

  "agent_map": {

    "_example_rename": "Rename only — keep sprite, position, everything else",
    "main": { "displayName": "Boss" },

    "_example_new_agent_type": "Map a new agent type (all fields required since key doesn't exist in base)",
    "everything-claude-code": { "sprite": "coder_a", "displayName": "ECC", "resident": true, "idlePosition": { "x": 14, "y": 8 } },

    "_example_move_seat": "Change idle position only",
    "Explore": { "idlePosition": { "x": 30, "y": 15 } },

    "_example_non_resident": "Make an agent appear only on hook events, not on page load",
    "frontend": { "resident": false }
  }
}
